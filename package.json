{
  "name": "vscode-lunaris-theme",
  "description": "A perfect theme for your codes",
  "version": "0.0.21",
  "author": {
    "name": "luas10c"
  },
  "displayName": "Lunaris",
  "icon": "icon.png",
  "keywords": [
    "theme",
    "lunaris"
  ],
  "publisher": "luas10c",
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "tsc-alias -f -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci",
    "test:watch": "jest --passWithNoTests --watch",
    "test:wacthAll": "jest --passWithNoTests --watchAll",
    "test:coverage": "jest --passWithNoTests --coverage",
    "pregenerate": "npm run build",
    "generate": "node dist/generate.js",
    "package": "vsce package --no-yarn -o dist",
    "publish": "vsce publish --no-yarn -p $PERSONAL_ACCESS_TOKEN --skip-duplicate"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@swc/jest": "^0.2.39",
    "@types/node": "^25.9.2",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.4.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Lunaris",
        "uiTheme": "vs-dark",
        "path": "./dist/themes/dark.json"
      }
    ]
  },
  "homepage": "https://github.com/luas10c/vscode-lunaris-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/luas10c/vscode-lunaris-theme"
  },
  "bugs": {
    "url": "https://github.com/luas10c/vscode-lunaris-theme/issues"
  },
  "engines": {
    "vscode": "^1.22.0"
  },
  "license": "MIT"
}
