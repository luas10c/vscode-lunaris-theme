{
  "name": "vscode-husky-theme",
  "description": "A simple theme with bright colors",
  "version": "0.0.8",
  "displayName": "Husky Oficial",
  "icon": "assets/logo.png",
  "keywords": [
    "theme",
    "husky"
  ],
  "publisher": "luas10c",
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc --project tsconfig.build.json && tsc-alias --project tsconfig.build.json",
    "pregenerate": "npm run build",
    "generate": "node dist/generate.js",
    "package": "vsce package --no-yarn -o dist",
    "publish": "vsce publish --no-yarn",
    "lint": "eslint . --config .eslintrc.cjs --ext js,ts",
    "type:checking": "tsc --project tsconfig.json",
    "husky:prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.6.7",
    "@commitlint/config-conventional": "^17.6.7",
    "@types/node": "^20.4.3",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "@vscode/vsce": "^2.19.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-promise": "^6.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "polished": "^4.2.2",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.1",
    "tsc-alias": "^1.8.7",
    "typescript": "^5.1.6"
  },
  "categories": [
    "Themes"
  ],
  "engines": {
    "node": "^16.14 || ^18.10",
    "vscode": "^1.22.0"
  },
  "homepage": "https://github.com/luas10c/vscode-husky-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/luas10c/vscode-husky-theme"
  },
  "bugs": {
    "url": "https://github.com/luas10c/vscode-husky-theme/issues",
    "email": "luas10c@gmail.com"
  },
  "author": {
    "name": "luas10c",
    "email": "luas10c@gmail.com"
  },
  "contributes": {
    "themes": [
      {
        "label": "Husky Dark",
        "uiTheme": "vs-dark",
        "path": "./src/themes/dark.json"
      },
      {
        "label": "Husky Dark Bordered",
        "uiTheme": "vs-dark",
        "path": "./src/themes/dark-bordered.json"
      }
    ]
  },
  "license": "MIT"
}
