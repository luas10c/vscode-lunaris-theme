{
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,

    "noImplicitAny": true,
    "noImplicitReturns": true,

    "rootDir": "src",

    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",

    "esModuleInterop": true,

    "types": ["node"],

    "paths": {
      "#/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
